<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Entitlements for the notarised Developer-ID build of bitHuman.app.

  Notes on each key:

  com.apple.security.app-sandbox
    Off (false). The avatar engine reads model weights from
    ~/Library/Application Support/ai.bithuman/, MLX writes Metal
    compiler caches to /private/tmp, and the user can drag-drop a
    portrait image from anywhere on disk. Sandboxing all of those
    paths cleanly is multi-day surgery — if/when we want App Store
    distribution we'll revisit, but for Developer-ID + Sparkle we
    ship un-sandboxed (which is what every other Developer-ID
    desktop app — Slack, 1Password CLI helper, etc. — does too).

  com.apple.security.cs.* (hardened runtime exemptions)
    The app is built with the codesign hardened-runtime option. We
    grant *targeted* exemptions only — the JIT and unsigned-mem
    flags are needed because MLX builds Metal shaders at runtime and
    the resulting .metallib gets mapped executable + writable.

  device.audio-input
    Microphone capture. Paired with NSMicrophoneUsageDescription in
    Info.plist; without both, AVAudioEngine init fails with
    OSStatus -10851 the first time we touch the input bus.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!--
      Hardened-runtime exemptions required by the MLX runtime.
      MLX dynamically compiles Metal kernels (allow-jit) and maps
      anonymous executable pages for the resulting shader code
      (allow-unsigned-executable-memory). Without these two keys
      the very first GPU dispatch traps with EXC_BAD_ACCESS when
      Apple's hardened-runtime page-protection refuses the
      writable+executable mapping.
    -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!--
      Disable library validation so MLX's resource bundles
      (mlx-swift_Cmlx.bundle/Contents/Resources/default.metallib)
      can be loaded even though they're signed by us, not Apple.
      This is the standard Developer-ID-with-bundles pattern.
    -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!--
      Microphone access. Speech transcription on macOS 26 piggybacks
      on the mic permission — we don't need a separate
      device.speech-recognition entitlement.
    -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
