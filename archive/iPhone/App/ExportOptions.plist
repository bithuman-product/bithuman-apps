<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Store distribution. For TestFlight + final App Store
         release. Switch `method` to `development` or `ad-hoc` for
         local install / on-device debug builds. -->
    <key>method</key>
    <string>app-store</string>

    <key>teamID</key>
    <string>G64NFNZX84</string>

    <!-- Automatic signing — Xcode resolves the App Store distribution
         certificate + provisioning profile for ai.bithuman.app.ios.
         Requires the developer account is logged into Xcode. -->
    <key>signingStyle</key>
    <string>automatic</string>

    <!-- App-thinning: ship a single universal IPA. App Store Connect
         re-thins per-device when distributing. -->
    <key>thinning</key>
    <string>&lt;none&gt;</string>

    <!-- Strip Swift symbols from the binary (dSYM is uploaded
         separately alongside the IPA). -->
    <key>stripSwiftSymbols</key>
    <true/>

    <!-- Embed dSYMs for the App Store's symbolicator. -->
    <key>uploadSymbols</key>
    <true/>

    <!-- Bitcode is dead post-Xcode 14; explicitly off. -->
    <key>uploadBitcode</key>
    <false/>
    <key>compileBitcode</key>
    <false/>
</dict>
</plist>
