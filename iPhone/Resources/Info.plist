<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Identity -->
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>bitHuman</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>ai.bithuman.app.ios</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- iPhone-only — explicitly NOT iPad. The phone variant has a
         portrait-locked, single-pane layout; the iPad app
         (Apps/BithumanPad) is a separate target with its own bundle
         id (ai.bithuman.app.ipad) and split-view layout. -->
    <key>UIDeviceFamily</key>
    <array>
        <integer>1</integer>
    </array>

    <!-- Hardware floor: A18 Pro. We don't have a Capabilities key
         that pins this, but the app's MLX models + avatar engine
         won't sustain frame budget on earlier silicon. Document in
         README + App Store description; soft-fail at launch with a
         helpful diagnostic if we detect anything older. -->

    <!-- Portrait only — the avatar engine's frame pump is sized for
         a single fixed orientation. Belt-and-braces alongside the
         runtime UIWindowScene.GeometryPreferences in
         BithumanPhoneApp.swift. -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <!-- Multitasking: iPhone only, so no Slide Over / Split View /
         Stage Manager keys (those are iPad-side). We do NOT declare
         UIRequiresFullScreen — that's an iPad concept. -->

    <!-- SwiftUI scene declaration -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>

    <!-- Status bar / launch -->
    <key>UIStatusBarHidden</key>
    <true/>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>
    <key>UILaunchScreen</key>
    <dict>
        <key>UIColorName</key>
        <string>LaunchBackground</string>
    </dict>

    <!-- Privacy -->
    <key>NSMicrophoneUsageDescription</key>
    <string>bitHuman needs microphone access for on-device voice conversation. Audio never leaves your phone.</string>
    <key>NSCameraUsageDescription</key>
    <string>bitHuman uses the camera so you can capture a portrait to bring a new agent to life.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>bitHuman lets you pick a photo from your library as a portrait for a new agent.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>bitHuman uses on-device speech recognition (SpeechAnalyzer) to transcribe your voice locally.</string>

    <!-- Memory headroom — the avatar engine + MLX models hold
         multi-GB of weights resident. The increased-memory-limit
         entitlement is requested in BithumanPhone.entitlements;
         see also memory note `project_ipad_ml_support.md`. -->

    <!-- App Store category -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.productivity</string>

    <!-- Background — we don't run background audio (conversation is
         strictly foreground). If/when we add ducked playback while
         the app is suspended, add UIBackgroundModes=audio here. -->
</dict>
</plist>
