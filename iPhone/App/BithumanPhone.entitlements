<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Increased memory limit
         The avatar engine + MLX-quantised LLM/TTS hold multi-GB of
         weights resident. Stock iOS apps are killed once their dirty
         footprint crosses the per-device jetsam threshold (which on
         a 8 GB iPhone is ~3 GB). With this entitlement Apple raises
         the ceiling so we can keep the model + frame buffers in
         memory without being jetsam'd between conversations.
         See memory note `project_ipad_ml_support.md`. -->
    <key>com.apple.developer.kernel.increased-memory-limit</key>
    <true/>

    <!-- Extended virtual addressing — paired with the above so the
         compressed (phys_footprint) accounting doesn't trip jetsam
         thresholds when MALLOC pool spills to swap. See memory note
         `project_peak_memory_phantom.md`. -->
    <key>com.apple.developer.kernel.extended-virtual-addressing</key>
    <true/>

    <!-- ANE / Neural Engine — implicit; no entitlement required for
         CoreML/MPS use. Listed here for posterity. -->

    <!-- App Sandbox — iOS apps are sandboxed by default; no key
         required. Listed here for posterity. -->
</dict>
</plist>
