<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bundle identity -->
    <key>CFBundleName</key>
    <string>bitHuman</string>
    <key>CFBundleDisplayName</key>
    <string>bitHuman</string>
    <key>CFBundleIdentifier</key>
    <string>ai.bithuman.app.ipad</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>

    <!-- iPad ONLY (UIDeviceFamily code 2). The bundle will refuse
         to install on iPhone — required because the avatar engine
         peaks at ~7.5 GB on a 16 GB device, and iPhones below 16 GB
         can't sustain it. -->
    <key>UIDeviceFamily</key>
    <array>
        <integer>2</integer>
    </array>

    <!-- Minimum iPad: any 16 GB+ model (M1+ iPad Pro / iPad Air M2+). -->
    <key>MinimumOSVersion</key>
    <string>26.0</string>

    <!-- Supported orientations: portrait + both landscape. Upside-
         down portrait is iPad-only on this family code; we leave it
         in so kickstand / stand cases work both ways. -->
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Use the SwiftUI `App` lifecycle. No storyboard / NIB. -->
    <key>UILaunchScreen</key>
    <dict>
        <key>UIColorName</key>
        <string></string>
        <key>UIImageName</key>
        <string></string>
    </dict>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>

    <!-- Memory entitlement: the avatar engine peaks at ~7.5 GB on a
         16 GB iPad. Apps without the `extended-virtual-addressing`
         + `increased-memory-limit` entitlements get killed by
         Jetsam at ~3 GB. The entitlement file in
         Resources/BithumanPad.entitlements requests both. -->

    <!-- Privacy strings — required by the App Store reviewer on
         first install when the engine asks for these permissions.
         Keep wording user-facing & concrete; reviewers reject
         developer-jargon copy. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>bitHuman listens to your voice so the avatar can hold a real-time conversation with you.</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>bitHuman transcribes your voice on-device using the system speech recognizer.</string>
    <key>NSCameraUsageDescription</key>
    <string>bitHuman can capture a portrait to animate as your avatar.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>bitHuman lets you pick a portrait from your photo library to animate as your avatar.</string>

    <!-- Background audio: needed so the chat keeps running when the
         user dims the screen or switches apps briefly. The voice-
         processing audio session has to stay live or full-duplex
         conversation tears at the resume. -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>

    <!-- Status bar appearance — let SwiftUI manage it. -->
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <true/>

    <!-- App Transport Security — leave defaults; bithuman is
         on-device, no networking required at runtime once weights
         are downloaded. -->
</dict>
</plist>
