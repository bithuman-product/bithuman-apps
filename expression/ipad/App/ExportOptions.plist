<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Store Connect / TestFlight upload. -->
    <key>method</key>
    <string>app-store-connect</string>
    <key>destination</key>
    <string>export</string>
    <!-- Placeholder. Scripts/build-ipad-app.sh substitutes this with
         your $DEVELOPMENT_TEAM env var before invoking xcodebuild. -->
    <key>teamID</key>
    <string>__DEVELOPMENT_TEAM__</string>
    <!-- Upload dSYMs so TestFlight crash logs symbolicate. -->
    <key>uploadSymbols</key>
    <true/>
    <!-- Bitcode is dead since Xcode 14. -->
    <key>uploadBitcode</key>
    <false/>
    <!-- Let Xcode pick the matching distribution provisioning
         profile from the developer portal. The user must have an
         App Store distribution cert + profile installed for this to
         resolve; see Apps/BithumanPad/README.md → "Release". -->
    <key>signingStyle</key>
    <string>automatic</string>
    <!-- Strip the Mach-O symbol table from the shipped binary; dSYMs
         retain the mapping for symbolication. -->
    <key>stripSwiftSymbols</key>
    <true/>
</dict>
</plist>
